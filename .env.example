# ════════════════════════════════════════════════════════════
# RASPIS — Firebase конфигурациясы
# ════════════════════════════════════════════════════════════
#
# НҰСҚАУЛЫҚ:
# 1. Осы файлдың көшірмесін жасап, ".env" деп атаңыз
#    (терминалда: cp .env.example .env)
#
# 2. Firebase консолінен кілттерді алыңыз:
#    • console.firebase.google.com → жобаңызды ашыңыз
#    • ⚙️ Project Settings → "Your apps" → Web app (</>)
#    • "SDK setup and configuration" → "Config" таңдаңыз
#    • firebaseConfig мәндерін төменге көшіріңіз
#
# 3. Firebase консолінде қосыңыз:
#    • Authentication → Sign-in method → Google → Enable
#    • Firestore Database → Create database → Production mode
#
# 4. Firestore ережелерін орнатыңыз (Rules қойындысы):
#    rules_version = '2';
#    service cloud.firestore {
#      match /databases/{database}/documents {
#        match /schools/{userId} {
#          allow read, write: if request.auth != null && request.auth.uid == userId;
#        }
#      }
#    }
#
# МАҢЫЗДЫ: бұл кілттер ашық болуға арналған (браузерде жұмыс істейді).
# Қауіпсіздікті жоғарыдағы Firestore ережелері қамтамасыз етеді —
# әр пайдаланушы тек ӨЗ деректерін көреді.
# ════════════════════════════════════════════════════════════

VITE_FIREBASE_API_KEY=осында_apiKey
VITE_FIREBASE_AUTH_DOMAIN=жоба.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=жоба_id
VITE_FIREBASE_STORAGE_BUCKET=жоба.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=сан_id
VITE_FIREBASE_APP_ID=app_id
